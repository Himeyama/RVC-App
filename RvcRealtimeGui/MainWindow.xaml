<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="RvcRealtimeGui.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="RVC リアルタイム音声変換">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid RowDefinitions="Auto,*">

        <!-- ── ナビゲーションバー ──────────────────────────────── -->
        <Grid x:Name="TitleBarGrid" Grid.Row="0" Height="48" Background="Transparent">
            <!-- タイトル（左） -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                        Margin="16,0,0,0" Spacing="8" HorizontalAlignment="Left">
                <FontIcon Glyph="&#xE767;" FontSize="16" VerticalAlignment="Center" />
                <TextBlock Text="RVC リアルタイム音声変換"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Grid>

        <!-- ── モード切り替え + コンテンツ ─────────────────────── -->
        <NavigationView Grid.Row="1" x:Name="RootNav"
                        PaneDisplayMode="Left" IsSettingsVisible="False"
                        IsBackButtonVisible="Collapsed"
                        IsPaneOpen="False"
                        SelectionChanged="RootNav_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="RVC モード" Tag="rvc" IsSelected="True">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE768;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="モデル調整モード" Tag="tuning">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE912;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>
            <Frame x:Name="ContentFrame" />
        </NavigationView>

    </Grid>
</Window>
