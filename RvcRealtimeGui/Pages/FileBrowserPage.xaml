<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="RvcRealtimeGui.Pages.FileBrowserPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid RowDefinitions="Auto,*,Auto" Padding="20,12,20,16">

        <!-- ツールバー: 戻る・進む・上へ・更新・新しいフォルダ・パス入力 -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,*" ColumnSpacing="8" Margin="0,0,0,12">
            <Button Grid.Column="0" x:Name="BackBtn" Click="BackBtn_Click"
                    ToolTipService.ToolTip="戻る">
                <FontIcon Glyph="&#xE72B;" FontSize="14" />
            </Button>
            <Button Grid.Column="1" x:Name="ForwardBtn" Click="ForwardBtn_Click"
                    ToolTipService.ToolTip="進む">
                <FontIcon Glyph="&#xE72A;" FontSize="14" />
            </Button>
            <Button Grid.Column="2" x:Name="UpBtn" Click="UpBtn_Click"
                    ToolTipService.ToolTip="上へ">
                <FontIcon Glyph="&#xE74A;" FontSize="14" />
            </Button>
            <Button Grid.Column="3" x:Name="RefreshBtn" Click="RefreshBtn_Click"
                    ToolTipService.ToolTip="更新">
                <FontIcon Glyph="&#xE72C;" FontSize="14" />
            </Button>
            <Button Grid.Column="4" x:Name="NewFolderBtn" Click="NewFolderBtn_Click"
                    ToolTipService.ToolTip="新しいフォルダ">
                <FontIcon Glyph="&#xE8F4;" FontSize="14" />
            </Button>
            <TextBox Grid.Column="5" x:Name="PathBox" VerticalAlignment="Center"
                     KeyDown="PathBox_KeyDown" />
        </Grid>

        <!-- フォルダ・ファイル一覧 -->
        <ListView Grid.Row="1" x:Name="EntryList"
                  SelectionMode="Single"
                  DoubleTapped="EntryList_DoubleTapped"
                  SelectionChanged="EntryList_SelectionChanged">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="{Binding Glyph}" FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                  FontSize="14" Width="16" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- フッター: ファイル名入力 + 拡張子フィルタ / 選択・キャンセル -->
        <Grid Grid.Row="2" RowDefinitions="Auto,Auto" Margin="0,12,0,0" RowSpacing="8">
            <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                <TextBlock Grid.Column="0" Text="ファイル名(N):" VerticalAlignment="Center" />
                <TextBox Grid.Column="1" x:Name="FileNameBox" VerticalAlignment="Center"
                         KeyDown="FileNameBox_KeyDown" TextChanged="FileNameBox_TextChanged" />
                <ComboBox Grid.Column="2" x:Name="ExtensionFilterCombo" Width="160"
                          SelectionChanged="ExtensionFilterCombo_SelectionChanged" />
            </Grid>
            <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                <Button Grid.Column="1" x:Name="SelectBtn" Content="開く(O)" Style="{ThemeResource AccentButtonStyle}"
                        IsEnabled="False" Click="SelectBtn_Click" />
                <Button Grid.Column="2" x:Name="CancelBtn" Content="キャンセル" Click="CancelBtn_Click" />
            </Grid>
        </Grid>
    </Grid>
</Page>
