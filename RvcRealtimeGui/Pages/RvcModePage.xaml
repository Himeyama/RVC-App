<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="RvcRealtimeGui.Pages.RvcModePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid RowDefinitions="*,Auto">

        <!-- ── VC 操作バー + 設定エリア（まとめてスクロール） ──── -->
        <ScrollViewer Grid.Row="0" Padding="20,8,20,8" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="14">

                <!-- VC 操作バー -->
                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Left">
                    <!-- サーバー起動/停止トグルボタン -->
                    <Button x:Name="ToggleServerBtn"
                            Height="32" Padding="12,0"
                            Style="{ThemeResource AccentButtonStyle}"
                            ToolTipService.ToolTip="api_gui.py を起動"
                            Click="ToggleServerBtn_Click">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon x:Name="ToggleServerIcon" Glyph="&#xE756;" FontSize="14" VerticalAlignment="Center" />
                            <TextBlock x:Name="ToggleServerText" Text="サーバー起動" VerticalAlignment="Center"
                                       Style="{ThemeResource CaptionTextBlockStyle}" />
                        </StackPanel>
                    </Button>
                    <!-- 音声変換 開始/停止トグル -->
                    <Button x:Name="ToggleVcBtn"
                            Height="32" Padding="12,0"
                            IsEnabled="False"
                            Style="{ThemeResource AccentButtonStyle}"
                            ToolTipService.ToolTip="音声変換 開始"
                            Click="ToggleVcBtn_Click">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon x:Name="ToggleVcIcon" Glyph="&#xE768;" FontSize="14" VerticalAlignment="Center" />
                            <TextBlock x:Name="VcSpinner" Text="⠋" FontSize="14"
                                       VerticalAlignment="Center" Visibility="Collapsed" />
                            <TextBlock x:Name="ToggleVcText" Text="音声変換 開始" VerticalAlignment="Center"
                                       Style="{ThemeResource CaptionTextBlockStyle}" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- モデル & デバイス（横並び） -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="14">

                    <!-- モデル読み込み -->
                    <Border Grid.Column="0"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="16">
                        <StackPanel Spacing="10">
                            <TextBlock Text="モデル読み込み"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}" />

                            <Grid ColumnDefinitions="150,*,Auto" ColumnSpacing="8">
                                <TextBlock Grid.Column="0" Text="モデル (.pth)" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1" x:Name="PthPathBox" />
                                <Button Grid.Column="2" x:Name="BrowsePthBtn" Content="参照..." Width="72"
                                        Click="BrowsePthBtn_Click" />
                            </Grid>

                            <Grid ColumnDefinitions="150,*,Auto" ColumnSpacing="8">
                                <TextBlock Grid.Column="0" Text="インデックス (.index)" VerticalAlignment="Center"
                                           TextWrapping="NoWrap" />
                                <TextBox Grid.Column="1" x:Name="IndexPathBox" />
                                <Button Grid.Column="2" x:Name="BrowseIndexBtn" Content="参照..." Width="72"
                                        Click="BrowseIndexBtn_Click" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- オーディオデバイス -->
                    <Border Grid.Column="1"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="16">
                        <StackPanel Spacing="10">
                            <TextBlock Text="オーディオデバイス"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}" />

                            <Grid ColumnDefinitions="80,*,Auto" ColumnSpacing="8">
                                <TextBlock Grid.Column="0" Text="種別" VerticalAlignment="Center" />
                                <ComboBox Grid.Column="1" x:Name="HostApiCombo" HorizontalAlignment="Stretch"
                                          SelectionChanged="HostApiCombo_SelectionChanged" />
                                <CheckBox Grid.Column="2" x:Name="WasapiExclusiveCheck" Content="WASAPI 排他" />
                            </Grid>

                            <Grid ColumnDefinitions="80,*" ColumnSpacing="8">
                                <TextBlock Grid.Column="0" Text="入力" VerticalAlignment="Center" />
                                <ComboBox Grid.Column="1" x:Name="InputDeviceCombo" HorizontalAlignment="Stretch"
                                          MinWidth="200">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" TextWrapping="NoWrap" TextTrimming="None" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </Grid>

                            <Grid ColumnDefinitions="80,*" ColumnSpacing="8">
                                <TextBlock Grid.Column="0" Text="出力" VerticalAlignment="Center" />
                                <ComboBox Grid.Column="1" x:Name="OutputDeviceCombo" HorizontalAlignment="Stretch"
                                          MinWidth="200">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" TextWrapping="NoWrap" TextTrimming="None" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </Grid>

                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                <Button Grid.Column="0" x:Name="ReloadDevicesBtn" Content="最新情報を取得"
                                        Click="ReloadDevicesBtn_Click" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12"
                                            VerticalAlignment="Center">
                                    <RadioButton x:Name="SrModelRadio" GroupName="SrType"
                                                 Content="モデルの SR" IsChecked="True" />
                                    <RadioButton x:Name="SrDeviceRadio" GroupName="SrType"
                                                 Content="デバイスの SR" />
                                    <TextBlock Text="SR:" VerticalAlignment="Center" />
                                    <TextBlock x:Name="SrLabel" Text="-" VerticalAlignment="Center"
                                               FontFamily="Consolas" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                </Grid>

                <!-- 基本 & パフォーマンス（横並び） -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="14">

                    <!-- 基本設定 -->
                    <Border Grid.Column="0"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="16">
                        <StackPanel Spacing="4">
                            <TextBlock Text="基本設定" Style="{ThemeResource BodyStrongTextBlockStyle}"
                                       Margin="0,0,0,4" />

                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="無音閾値 (dB)" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" x:Name="ThresholdVal" Text="-60" VerticalAlignment="Center"
                                           FontFamily="Consolas" MinWidth="40" TextAlignment="Right" />
                            </Grid>
                            <Slider x:Name="ThresholdSlider" Minimum="-60" Maximum="0" StepFrequency="1" Value="-60"
                                    ValueChanged="ThresholdSlider_ValueChanged" />

                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="ピッチ (半音)" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" x:Name="PitchVal" Text="0" VerticalAlignment="Center"
                                           FontFamily="Consolas" MinWidth="40" TextAlignment="Right" />
                            </Grid>
                            <Slider x:Name="PitchSlider" Minimum="-16" Maximum="16" StepFrequency="1" Value="0"
                                    ValueChanged="PitchSlider_ValueChanged" />

                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="フォルマント" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" x:Name="FormantVal" Text="0.00" VerticalAlignment="Center"
                                           FontFamily="Consolas" MinWidth="40" TextAlignment="Right" />
                            </Grid>
                            <Slider x:Name="FormantSlider" Minimum="-2" Maximum="2" StepFrequency="0.05" Value="0"
                                    ValueChanged="FormantSlider_ValueChanged" />

                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="インデックス強度" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" x:Name="IndexRateVal" Text="0.00" VerticalAlignment="Center"
                                           FontFamily="Consolas" MinWidth="40" TextAlignment="Right" />
                            </Grid>
                            <Slider x:Name="IndexRateSlider" Minimum="0" Maximum="1" StepFrequency="0.01" Value="0"
                                    ValueChanged="IndexRateSlider_ValueChanged" />

                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="音量ミックス率" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" x:Name="RmsMixVal" Text="0.00" VerticalAlignment="Center"
                                           FontFamily="Consolas" MinWidth="40" TextAlignment="Right" />
                            </Grid>
                            <Slider x:Name="RmsMixSlider" Minimum="0" Maximum="1" StepFrequency="0.01" Value="0"
                                    ValueChanged="RmsMixSlider_ValueChanged" />

                            <TextBlock Text="F0 推定アルゴリズム" Margin="0,6,0,0" />
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <RadioButton x:Name="F0PmRadio"      GroupName="F0" Content="pm" />
                                <RadioButton x:Name="F0HarvestRadio" GroupName="F0" Content="harvest" />
                                <RadioButton x:Name="F0CrepeRadio"   GroupName="F0" Content="crepe" />
                                <RadioButton x:Name="F0RmvpeRadio"   GroupName="F0" Content="rmvpe" />
                                <RadioButton x:Name="F0FcpeRadio"    GroupName="F0" Content="fcpe" IsChecked="True" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- パフォーマンス設定 -->
                    <Border Grid.Column="1"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="16">
                        <StackPanel Spacing="4">
                            <TextBlock Text="パフォーマンス設定" Style="{ThemeResource BodyStrongTextBlockStyle}"
                                       Margin="0,0,0,4" />

                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="バッファ長 (秒)" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" x:Name="BlockTimeVal" Text="0.25" VerticalAlignment="Center"
                                           FontFamily="Consolas" MinWidth="40" TextAlignment="Right" />
                            </Grid>
                            <Slider x:Name="BlockTimeSlider" Minimum="0.02" Maximum="1.5" StepFrequency="0.01" Value="0.25"
                                    ValueChanged="BlockTimeSlider_ValueChanged" />

                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="Harvest CPU スレッド数" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" x:Name="NCpuVal" Text="4" VerticalAlignment="Center"
                                           FontFamily="Consolas" MinWidth="40" TextAlignment="Right" />
                            </Grid>
                            <Slider x:Name="NCpuSlider" Minimum="1" Maximum="8" StepFrequency="1" Value="4"
                                    ValueChanged="NCpuSlider_ValueChanged" />

                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="クロスフェード長 (秒)" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" x:Name="CrossfadeVal" Text="0.05" VerticalAlignment="Center"
                                           FontFamily="Consolas" MinWidth="40" TextAlignment="Right" />
                            </Grid>
                            <Slider x:Name="CrossfadeSlider" Minimum="0.01" Maximum="0.15" StepFrequency="0.01" Value="0.05"
                                    ValueChanged="CrossfadeSlider_ValueChanged" />

                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="追加推論時間 (秒)" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" x:Name="ExtraTimeVal" Text="2.50" VerticalAlignment="Center"
                                           FontFamily="Consolas" MinWidth="40" TextAlignment="Right" />
                            </Grid>
                            <Slider x:Name="ExtraTimeSlider" Minimum="0.05" Maximum="5.0" StepFrequency="0.01" Value="2.5"
                                    ValueChanged="ExtraTimeSlider_ValueChanged" />

                            <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,8,0,0">
                                <CheckBox x:Name="INoiseCheck" Content="入力ノイズ除去" />
                                <CheckBox x:Name="ONoiseCheck" Content="出力ノイズ除去" />
                                <CheckBox x:Name="UsePvCheck" Content="フェーズボコーダー" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

            </StackPanel>
        </ScrollViewer>

        <!-- ── ターミナル + ステータスバー（下部固定） ─────────── -->
        <Grid Grid.Row="1" RowDefinitions="Auto,Auto">
            <!-- ターミナル（折りたたみ可能） -->
            <Grid Grid.Row="0" x:Name="TerminalPanel" RowDefinitions="Auto,Auto" Height="220">
                <!-- ターミナルヘッダー -->
                <Border Grid.Row="0"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="0,1,0,0" Padding="16,4">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE756;" FontSize="13"
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Text="サーバーログ"
                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <Button Grid.Column="1" x:Name="ClearTerminalBtn" Content="クリア"
                                Height="24" Padding="8,0"
                                Click="ClearTerminalBtn_Click" />
                    </Grid>
                </Border>
                <!-- xterm.js ターミナル（WebView2） -->
                <WebView2 Grid.Row="1" x:Name="TerminalWebView" Height="180"
                          NavigationCompleted="TerminalWebView_NavigationCompleted" />
            </Grid>

            <!-- ステータスバー -->
            <Border Grid.Row="1"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="0,1,0,0" Padding="16,6">
                <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto">
                    <!-- 変換状態 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE768;" FontSize="13"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="VcStatusLabel" Text="停止中" VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Style="{ThemeResource CaptionTextBlockStyle}" />
                    </StackPanel>

                    <!-- 遅延 -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center"
                                Margin="24,0,0,0">
                        <FontIcon Glyph="&#xE916;" FontSize="13"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="遅延" VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Style="{ThemeResource CaptionTextBlockStyle}" />
                        <TextBlock x:Name="DelayLabel" Text="— ms" VerticalAlignment="Center"
                                   FontFamily="Consolas"
                                   Style="{ThemeResource CaptionTextBlockStyle}" />
                    </StackPanel>

                    <!-- 推論 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center"
                                Margin="24,0,0,0">
                        <FontIcon Glyph="&#xE9D9;" FontSize="13"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="推論" VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Style="{ThemeResource CaptionTextBlockStyle}" />
                        <TextBlock x:Name="InferLabel" Text="— ms" VerticalAlignment="Center"
                                   FontFamily="Consolas"
                                   Style="{ThemeResource CaptionTextBlockStyle}" />
                    </StackPanel>

                    <!-- サーバー接続状態 -->
                    <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center"
                                Margin="24,0,0,0">
                        <FontIcon Glyph="&#xEBD2;" FontSize="13"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Name="ServerLabel" Text="未接続" VerticalAlignment="Center"
                                   Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                   Style="{ThemeResource CaptionTextBlockStyle}" />
                    </StackPanel>

                    <!-- ログ折りたたみトグル -->
                    <Button Grid.Column="5" x:Name="ToggleTerminalBtn"
                            Height="24" Padding="8,0"
                            Click="ToggleTerminalBtn_Click">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon x:Name="ToggleTerminalIcon" Glyph="&#xE70D;" FontSize="10" VerticalAlignment="Center" />
                            <TextBlock Text="ログ" VerticalAlignment="Center"
                                       Style="{ThemeResource CaptionTextBlockStyle}" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</Page>
